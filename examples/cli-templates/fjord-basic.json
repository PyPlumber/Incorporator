{
  "outflow": "outflow_example.py",

  "stream_params": [
    {
      "cls_name": "SpaceXLaunch",
      "incorp_params": {
        "inc_url": "https://api.spacexdata.com/v4/launches/latest",
        "inc_code": "id"
      }
    },
    {
      "cls_name": "SpaceXRocket",
      "incorp_params": {
        "inc_url": "https://api.spacexdata.com/v4/rockets",
        "inc_code": "id"
      }
    }
  ],

  "export_params": {
    "file_path": "data/launch_with_rocket.ndjson"
  },

  "refresh_interval": {"SpaceXLaunch": 60, "SpaceXRocket": 600},
  "export_interval": 120.0
}
