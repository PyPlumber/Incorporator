{
  "window": {
    "start": "@window_start",
    "end": "@window_end"
  },

  "shape": "parallel",
  "outflow": "outflow.py",
  "drain_timeout": 25,

  "currents": [
    {
      "name": "binance_stats",
      "class": "BinanceStat",
      "verb": "stream",
      "interval": 90,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://api.binance.us/api/v3/ticker/24hr",
        "inc_code": "symbol",
        "excl_lst": ["priceChangePercent", "weightedAvgPrice", "openPrice", "prevClosePrice"]
      }
    },
    {
      "name": "binance_books",
      "class": "BinanceBook",
      "verb": "stream",
      "interval": 90,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://api.binance.us/api/v3/ticker/bookTicker",
        "inc_code": "symbol"
      }
    },
    {
      "name": "crypto_assets",
      "class": "CryptoAsset",
      "verb": "stream",
      "interval": 90,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=100&page=1",
        "inc_code": "id",
        "inc_name": "name",
        "conv_dict": {
          "current_price": "inc(float, default=0.0)",
          "symbol": "calc(upper_symbol, 'symbol', default='', target_type=str)",
          "market_cap_rank": "inc(int, default=0)"
        }
      }
    },
    {
      "name": "liquidity",
      "class": "CryptoLiquidity",
      "verb": "fjord",
      "interval": 8,
      "on_error": "isolate",
      "parent_currents": ["binance_stats", "binance_books", "crypto_assets"],
      "export_params": {
        "file_path": "out/crypto_liquidity.ndjson",
        "format": "ndjson",
        "if_exists": "replace"
      }
    }
  ]
}
