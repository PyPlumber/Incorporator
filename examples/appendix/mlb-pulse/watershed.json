{
  "window": {
    "start": "@window_start",
    "end": "@window_end"
  },

  "shape": "diamond",
  "outflow": "outflow.py",
  "drain_timeout": 15,
  "gate_mode": "weir",
  "host_penstocks": {
    "statsapi.mlb.com": {"rate_per_sec": 1.0}
  },

  "head": {
    "name": "al_teams",
    "class": "MLBAllTeam",
    "verb": "stream",
    "interval": 20,
    "on_error": "isolate",
    "incorp_params": {
      "inc_url": "https://statsapi.mlb.com/api/v1/teams?sportId=1&leagueId=103",
      "rec_path": "teams",
      "inc_code": "id",
      "inc_name": "name"
    }
  },

  "middle": [
    {
      "name": "standings",
      "class": "MLBStandings",
      "verb": "stream",
      "interval": 20,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/standings?leagueId=103",
        "rec_path": "records",
        "inc_code": "division.id"
      }
    },
    {
      "name": "hitting",
      "class": "MLBHitting",
      "verb": "stream",
      "interval": 25,
      "on_error": "isolate",
      "parent_current": "al_teams",
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/teams/{}/stats?group=hitting&stats=season&season=2026",
        "inc_child": "inc_code",
        "rec_path": "stats.0.splits.0",
        "inc_code": "team.id",
        "conv_dict": {
          "ops": "calc(float, 'stat.ops', default=0.0, target_type=float)"
        }
      }
    },
    {
      "name": "pitching",
      "class": "MLBPitching",
      "verb": "stream",
      "interval": 25,
      "on_error": "isolate",
      "parent_current": "al_teams",
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/teams/{}/stats?group=pitching&stats=season&season=2026",
        "inc_child": "inc_code",
        "rec_path": "stats.0.splits.0",
        "inc_code": "team.id",
        "conv_dict": {
          "era": "calc(float, 'stat.era', default=9.99, target_type=float)"
        }
      }
    }
  ],

  "tail": {
    "name": "pulse",
    "class": "TeamPulseCard",
    "verb": "fjord",
    "interval": 5,
    "on_error": "isolate",
    "export_params": {
      "file_path": "out/al_pulse.ndjson",
      "format": "ndjson",
      "if_exists": "replace"
    }
  }
}
