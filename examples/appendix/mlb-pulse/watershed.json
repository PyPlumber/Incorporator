{
  "_comment_1_": "CLI-declarative form of the MLB AL East Pulse diamond.",
  "_comment_2_": "Relative outflow path is resolved against this JSON's parent directory,",
  "_comment_3_": "so the example runs from any working directory:",
  "_comment_4_": "  incorporator validate examples/appendix/mlb-pulse/watershed.json",
  "_comment_5_": "  incorporator tideweaver run examples/appendix/mlb-pulse/watershed.json",
  "_comment_6_": "Override the default window with env vars: PULSE_START / PULSE_END (ISO 8601, UTC).",
  "_comment_7_": "hitting and pitching nodes use verb: stream with parent_current='all_teams' for",
  "_comment_8_": "T5 parent-child fan-out. conv_dict values are call-grammar strings resolved by",
  "_comment_9_": "incorporator/cli/tokens.py at load time: 'calc(float, \"stat.ops\", default=0.0)'",
  "_comment_10_": "parses to a real CalcOp instance via the safe-eval allow-list.",
  "window": {
    "start": "${PULSE_START:-2026-05-28T00:00:00+00:00}",
    "end":   "${PULSE_END:-2026-05-28T00:00:25+00:00}"
  },

  "shape": "diamond",
  "outflow": "pulse_outflow.py",
  "drain_timeout": 20,
  "gate_mode": "weir",

  "head": {
    "name": "schedule",
    "class": "MLBSchedule",
    "verb": "stream",
    "interval": 8,
    "on_error": "isolate",
    "incorp_params": {
      "inc_url": "https://statsapi.mlb.com/api/v1/schedule?sportId=1",
      "rec_path": "dates.0.games",
      "inc_code": "gamePk",
      "inc_name": "teams.home.team.name"
    }
  },

  "middle": [
    {
      "name": "all_teams",
      "class": "MLBAllTeam",
      "verb": "stream",
      "interval": 20,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/teams?sportId=1",
        "rec_path": "teams",
        "inc_code": "id",
        "inc_name": "name",
        "conv_dict": {
          "division_id": "calc(int, 'division.id', default=0)"
        }
      }
    },
    {
      "name": "standings",
      "class": "MLBStandings",
      "verb": "stream",
      "interval": 8,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/standings?leagueId=103",
        "rec_path": "records",
        "inc_code": "division.id",
        "inc_name": "division.name"
      }
    },
    {
      "name": "hitting",
      "class": "MLBHitting",
      "verb": "stream",
      "interval": 6,
      "on_error": "isolate",
      "parent_current": "all_teams",
      "parent_filter": ["division_id", "@operator_eq", 201],
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/teams/{}/stats?group=hitting&stats=season&season=2026",
        "inc_child": "inc_code",
        "rec_path": "stats.0.splits.0",
        "inc_code": "team.id",
        "conv_dict": {
          "ops": "calc(float, 'stat.ops', default=0.0)"
        }
      }
    },
    {
      "name": "pitching",
      "class": "MLBPitching",
      "verb": "stream",
      "interval": 6,
      "on_error": "isolate",
      "parent_current": "all_teams",
      "parent_filter": ["division_id", "@operator_eq", 201],
      "incorp_params": {
        "inc_url": "https://statsapi.mlb.com/api/v1/teams/{}/stats?group=pitching&stats=season&season=2026",
        "inc_child": "inc_code",
        "rec_path": "stats.0.splits.0",
        "inc_code": "team.id",
        "conv_dict": {
          "era": "calc(float, 'stat.era', default=9.99)"
        }
      }
    }
  ],

  "tail": {
    "name": "pulse",
    "class": "TeamPulseCard",
    "verb": "fjord",
    "interval": 4,
    "on_error": "isolate",
    "export_params": {
      "file_path": "out/al_east_pulse.ndjson",
      "format": "ndjson",
      "if_exists": "replace"
    }
  }
}
