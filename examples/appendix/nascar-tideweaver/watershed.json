{
  "window": {
    "start": "@window_start",
    "end": "@window_end"
  },

  "shape": "diamond",
  "outflow": "outflow.py",
  "drain_timeout": 10.0,

  "flow": {
    "gate":      {"type": "hard"},
    "reservoir": {"depth": 1},
    "spillway":  {"type": "drop_oldest"},
    "observer":  {"type": "logging", "fire_level": "info", "skip_level": "debug", "spillway_level": "warning"}
  },

  "head": {
    "name": "laps",
    "class": "LapData",
    "verb": "stream",
    "interval": 3.0,
    "incorp_params": {
      "inc_file": "fixtures/laps.json",
      "inc_code": "driver",
      "conv_dict": {
        "lap_number": "inc(int, default=0)"
      }
    }
  },

  "middle": [
    {
      "name": "pits",
      "class": "PitStops",
      "verb": "stream",
      "interval": 3.0,
      "incorp_params": {
        "inc_file": "fixtures/pits.json",
        "inc_code": "driver"
      }
    },
    {
      "name": "flags",
      "class": "FlagEvents",
      "verb": "stream",
      "interval": 3.0,
      "incorp_params": {
        "inc_file": "fixtures/flags.json",
        "inc_code": "color"
      }
    }
  ],

  "tail": {
    "name": "state",
    "class": "DriverState",
    "verb": "fjord",
    "interval": 3.0,
    "export_params": {
      "file_path": "out/driver_state.ndjson",
      "format": "ndjson",
      "if_exists": "append"
    }
  }
}
