{
  "_comment_1_": "Sample watershed.json for the NASCAR diamond pattern.",
  "_comment_2_": "Relative inc_file / outflow paths are resolved against this JSON's parent directory,",
  "_comment_3_": "so the example runs from any working directory:",
  "_comment_4_": "  incorporator validate examples/appendix/nascar-tideweaver/watershed.json",
  "_comment_5_": "  incorporator tideweaver run examples/appendix/nascar-tideweaver/watershed.json --json-output",
  "_comment_6_": "Override the default window with env vars: RACE_START / RACE_END (ISO 8601, UTC).",

  "window": {
    "start": "${RACE_START:-2026-05-16T00:00:00+00:00}",
    "end":   "${RACE_END:-2026-12-31T23:59:59+00:00}"
  },

  "shape": "diamond",
  "outflow": "outflow.py",
  "drain_timeout": 30,

  "_flow_note_": "Full FlowControl literal on every diamond edge — same runtime semantics as the gate_mode='hard' shorthand, but adds a LoggingObserver so per-edge fire / skip / spillway events emit through Python logging.  Switch any field's `type` value to swap strategies (see docs/api_atlas.md#canal-toolkit-primitives).",

  "flow": {
    "gate":      {"type": "hard"},
    "reservoir": {"depth": 1},
    "spillway":  {"type": "drop_oldest"},
    "observer":  {"type": "logging", "fire_level": "info", "skip_level": "debug", "spillway_level": "warning"}
  },

  "head": {
    "name": "laps",
    "class": "LapData",
    "verb": "stream",
    "interval": 30,
    "incorp_params": {
      "inc_file": "fixtures/laps.json",
      "inc_code": "driver",
      "conv_dict": {
        "lap_number": "inc(int, default=0)"
      }
    }
  },

  "middle": [
    {
      "name": "pits",
      "class": "PitStops",
      "verb": "stream",
      "interval": 30,
      "incorp_params": {
        "inc_file": "fixtures/pits.json",
        "inc_code": "driver"
      }
    },
    {
      "name": "flags",
      "class": "FlagEvents",
      "verb": "stream",
      "interval": 30,
      "incorp_params": {
        "inc_file": "fixtures/flags.json",
        "inc_code": "color"
      }
    }
  ],

  "tail": {
    "name": "state",
    "class": "DriverState",
    "verb": "fjord",
    "interval": 30,
    "export_params": {
      "file_path": "data/driver_state.ndjson",
      "format": "ndjson",
      "if_exists": "append"
    }
  }
}
