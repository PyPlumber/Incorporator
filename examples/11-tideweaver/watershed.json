{
  "_comment_1_": "Sample watershed.json for the multi-exchange arb-scanner diamond pattern.",
  "_comment_2_": "Relative inc_file / outflow paths are resolved against this JSON's parent directory,",
  "_comment_3_": "so the example runs from any working directory:",
  "_comment_4_": "  incorporator validate examples/11-tideweaver/watershed.json",
  "_comment_5_": "  incorporator tideweaver run examples/11-tideweaver/watershed.json --json-output",
  "_comment_6_": "Local JSON snapshots keep the CLI smoke-test runnable without network.",
  "_comment_7_": "Swap inc_file for inc_url against live exchange endpoints in production:",
  "_comment_8_": "  binance:  https://api.binance.us/api/v3/ticker/bookTicker",
  "_comment_9_": "  coinbase: https://api.exchange.coinbase.com/products/BTC-USD/ticker",
  "_comment_10_": "  kraken:   https://api.kraken.com/0/public/Ticker?pair=XBTUSD,ETHUSD (with rec_path: result)",

  "window": {
    "start": "${WINDOW_START:-2026-05-16T00:00:00+00:00}",
    "end":   "${WINDOW_END:-2026-12-31T23:59:59+00:00}"
  },

  "shape": "diamond",
  "outflow": "outflow.py",
  "drain_timeout": 30,
  "gate_mode": "hard",

  "head": {
    "name": "binance",
    "class": "BinanceBook",
    "verb": "stream",
    "interval": 15,
    "incorp_params": {
      "inc_file": "fixtures/binance_book.json",
      "inc_code": "symbol",
      "conv_dict": {
        "asset": "calc(normalize_asset, 'symbol', default=None)",
        "bid": "calc(float, 'bidPrice', default=0.0, target_type=float)",
        "ask": "calc(float, 'askPrice', default=0.0, target_type=float)"
      }
    }
  },

  "middle": [
    {
      "name": "coinbase",
      "class": "CoinbaseTicker",
      "verb": "stream",
      "interval": 30,
      "incorp_params": {
        "inc_file": "fixtures/coinbase_ticker.json",
        "inc_code": "trade_id",
        "conv_dict": {
          "asset": "calc(normalize_asset, 'product_id', default=None)",
          "bid": "calc(float, 'bid', default=0.0, target_type=float)",
          "ask": "calc(float, 'ask', default=0.0, target_type=float)"
        }
      }
    },
    {
      "name": "kraken",
      "class": "KrakenTicker",
      "verb": "stream",
      "interval": 30,
      "incorp_params": {
        "inc_file": "fixtures/kraken_ticker.json",
        "inc_code": "pair",
        "name_chg": [["_key", "pair"]],
        "conv_dict": {
          "asset": "calc(normalize_asset, '_key', default=None)",
          "bid": "calc(float, 'b.0', default=0.0, target_type=float)",
          "ask": "calc(float, 'a.0', default=0.0, target_type=float)"
        }
      }
    }
  ],

  "tail": {
    "name": "best_market",
    "class": "BestMarket",
    "verb": "fjord",
    "interval": 30,
    "export_params": {
      "file_path": "data/arb_signals.ndjson",
      "format": "ndjson",
      "if_exists": "append"
    }
  }
}
