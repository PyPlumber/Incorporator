{
  "window": {
    "start": "@window_start",
    "end": "@window_end"
  },

  "shape": "chain",
  "inflow": "inflow.py",
  "gate_mode": "hard",
  "drain_timeout": 45,

  "currents": [
    {
      "name": "coin",
      "class": "Coin",
      "verb": "stream",
      "interval": 300,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://api.coingecko.com/api/v3/coins/markets",
        "params": {"vs_currency": "usd", "per_page": 10, "page": 1},
        "inc_code": "id",
        "inc_name": "name",
        "excl_lst": ["image"],
        "requests_per_second": 0.2
      }
    },
    {
      "name": "coin_detail",
      "class": "CoinDetail",
      "verb": "stream",
      "parent_current": "coin",
      "interval": 300,
      "on_error": "isolate",
      "incorp_params": {
        "inc_url": "https://api.coingecko.com/api/v3/coins/{}",
        "inc_child": "id",
        "inc_code": "id",
        "excl_lst": ["image", "tickers", "community_data", "developer_data"],
        "requests_per_second": 0.2,
        "conv_dict": {
          "links_homepage": "pluck('links.homepage')",
          "genesis_date": "inc(str, default='-')"
        }
      }
    },
    {
      "name": "export_coin_detail",
      "class": "CoinDetail",
      "verb": "export",
      "depends_on": ["coin_detail"],
      "interval": 10,
      "on_error": "isolate",
      "export_params": {
        "file_path": "out/coin_details.ndjson",
        "format": "ndjson",
        "if_exists": "replace"
      }
    }
  ]
}
