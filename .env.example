# Incorporator — Local Dev Secrets Template
# ===========================================
#
# Copy this file to `.env` (gitignored) and fill in your secrets.
# Reference them from pipeline.json via `${VAR_NAME}` — they're expanded
# at JSON-load time inside the container.
#
# Example pipeline.json snippet:
#   "headers": { "Authorization": "Bearer ${BEARER_TOKEN}" }
#
# Production note: env vars are visible to anyone with access to the
# Docker daemon (`docker inspect`). For production, prefer mounted
# secret files referenced via `${file:/run/secrets/<name>}` (Docker
# Swarm Secrets / Kubernetes Secrets mount tmpfs files there).

# ---- Authentication ----
# API_KEY=
# BEARER_TOKEN=

# ---- Database / Export Backends ----
# DATABASE_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
