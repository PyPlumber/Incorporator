# ========================================
# Incorporator: Git Ignore Definitions
# ========================================

# 1. Python Bytecode & Cache
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/

# 2. Virtual Environments
venv/
.venv/
env/
ENV/
.env

# 3. Secrets & Orchestration Configs (CRITICAL SAFETY)
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json
client_secret.json
pipeline.json
local_*.json

# 4. PyCharm, VSCode & IDE Settings
.idea/
.vscode/
*.swp
*.swo
.ipynb_checkpoints/

# 5. Testing & Coverage
.pytest_cache/
.tox/
.coverage
htmlcov/
tests/public/api/real/

# 6. Build Artifacts & Packaging
build/
dist/
*.egg-info/
incorporator.egg-info/
AGENTS.md
/.claude/
site/

# 7. OS & Database Files
.DS_Store
Thumbs.db
*.db
*.sqlite
*.sqlite3

# 8. Incorporator Log Files
# Scoped to repo-root only so a tutorial generating ``examples/<dir>/logs/`` or
# its own .log fixture isn't silently dropped on commit.
/logs/
*.log
pip-log.txt
pip-delete-this-directory.txt

# Session-only benchmark output (per-run timing capture); the curated
# results live in docs/benchmark_results_*.md if/when committed.
bench_*.txt

# 9. ETL Data Feeds & Local Outputs
data/
output_data/
temp_*.json
final_*.json
*website_feed.json
*.csv
*.tsv
*.xml
*.avro

# Every tutorial that generates output writes to its own ``out/`` subdir so
# runtime artifacts have one consistent home that's always gitignored.
examples/**/out/

# Sample fixtures intentionally committed (override the above patterns).
# The negation must list every extension we want to keep, since rule 9 ignores
# the file-extension itself — any new fixture extension needs a sibling line.
!examples/**/*.xml
!examples/**/*.json
!examples/**/*.csv
!examples/**/*.tsv
!tests/**/*.xml
!tests/**/*.json
!tests/**/*.csv

# 10. Private Developer Scripts
real_*.py
/tests/demo/
.pypirc