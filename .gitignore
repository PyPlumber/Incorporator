# ========================================
# Incorporator: Git Ignore Definitions
# ========================================

# 1. Python Bytecode & Cache
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/

# 2. Virtual Environments
venv/
.venv/
env/
ENV/

# 3. Secrets & Orchestration Configs (CRITICAL SAFETY)
.env
.env.*
*.pem
*.key
credentials.json
secrets.json
client_secret.json
pipeline.json
local_*.json

# 4. PyCharm, VSCode & IDE Settings
.idea/
.vscode/
*.swp
*.swo
.ipynb_checkpoints/

# 5. Testing & Coverage
.pytest_cache/
.tox/
.coverage
htmlcov/
tests/public/api/real/

# 6. Build Artifacts & Packaging
build/
dist/
*.egg-info/
incorporator.egg-info/

# 7. OS & Database Files
.DS_Store
Thumbs.db
*.db
*.sqlite
*.sqlite3

# 8. Incorporator Log Files
logs/
*.log
pip-log.txt
pip-delete-this-directory.txt

# 9. ETL Data Feeds & Local Outputs
data/
output_data/
temp_*.json
final_*.json
*website_feed.json
*.csv
*.tsv
*.xml
*.avro

# 10. Private Developer Scripts
real_*.py
/tests/demo/
.pypirc