# ========================================
# Incorporator: Git Ignore Definitions
# ========================================

# 1. Python Bytecode & Cache
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/

# 2. Virtual Environments
venv/
.venv/
env/

# 3. Secrets & Credentials (CRITICAL SAFETY)
.env
.env.*
*.pem
*.key
credentials.json
secrets.json
client_secret.json

# 4. PyCharm, VSCode & IDE Settings
.idea/
.vscode/
*.swp
*.swo
.ipynb_checkpoints/

# 5. Testing & Coverage
.pytest_cache/
.tox/
.coverage
htmlcov/
tests/public/api/real

# 6. Build Artifacts & Packaging
build/
dist/
*.egg-info/
incorporator.egg-info/

# 7. OS Specific Files
.DS_Store
Thumbs.db
*.sqlite3

# 8. Incorporator Log Files
*.log
pip-log.txt
pip-delete-this-directory.txt

# 9. Temporary ETL Data Feeds & Output
temp_*.json
final_*.json
*website_feed.json
*.csv
*.xml

# 10. Private Developer Scripts
real_*.py
/tests/demo/
